@baseUrl = http://localhost:5000
@adminToken = admin_token

### Create General Announcement And Send Email
POST {{baseUrl}}/api/announcements
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "title": "Morning Shuttle Delay Test 2",
  "message": "Testing email after unblocking recipient.",
  "priority": "high",
  "scope": "general",
  "isActive": true
}