@baseUrl = http://localhost:5000
@adminToken = Admin_Token

### Create General Announcement
POST {{baseUrl}}/api/announcements
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "title": "Morning Shuttle Delay",
  "message": "The morning shuttle may be delayed by 10 minutes due to traffic.",
  "priority": "high",
  "scope": "general",
  "isActive": true
}